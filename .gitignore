# Dependencies — never committed, regenerated with npm install
node_modules/

# Expo build artifacts and cache
.expo/
dist/
web-build/
expo-env.d.ts

# Native project folders — generated by expo prebuild, not hand-edited
android/
ios/

# Metro bundler cache
.metro-health-check*

# Environment variables — contain secrets, never committed
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Signing and certificate files — contain secrets
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*

# TypeScript build info
*.tsbuildinfo

# OS junk
.DS_Store
Thumbs.db

# Editor folders
.vscode/
.idea/

# Logs
npm-debug.*
yarn-debug.*
yarn-error.*
*.log
